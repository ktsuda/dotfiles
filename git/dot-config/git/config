[user]
    name = ktsuda
    email = ktsuda@users.noreply.github.com
[core]
    editor = nvim
    pager = cat
    ignoreCase = false
    excludesFile = ~/.config/git/ignore
    quotepath = false
[merge]
    conflictStyle = diff3
[push]
    default = simple
    autoSetupRemote = true
[diff]
    colorMoved = default
    colorMovedWS = allow-indentation-change
[alias]
    fix = commit --amend
    now = commit --amend --no-edit
    l = log --graph --date-order --abbrev-commit --date=short --pretty=format:'%C("#89dceb")%ad %C("#cba6f7")%h %C("#a6e3a1")%cn %C("#cdd6f4")%s %C("#f9e2af")%d%Creset'
    clang-format = clang-format-12
[init]
    defaultBranch = main
[clangFormat]
    binary = clang-format-12
    style = file
[ghq]
    root = ~/Library/Mobile Documents/iCloud~md~obsidian
    root = ~/Projects
    root = ~/go/src
    root = ~/src

