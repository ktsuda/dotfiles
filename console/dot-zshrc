# prompt
function _jj_prompt_info() {
  jj log -G -r @ -T '
    self.change_id().shortest(3)
    ++ if(self.local_bookmarks(), "on " ++ self.local_bookmarks())
    ++ if(self.conflict(), "💥")
  ' --no-pager 2>/dev/null
}

function _vcs_status() {
  if jj root >/dev/null 2>&1; then
    echo -n "%F{#cba6f7}.jj%f %F{#fab387}$(_jj_prompt_info)%f"
  elif git rev-parse --show-toplevel >/dev/null 2>&1; then
    echo -n "%F{#cba6f7}.git%f %F{#a6e3a1}$(git branch --show-current)%f"
  fi
}

setopt prompt_subst
