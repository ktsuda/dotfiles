function _jj_log_oneliner() {
  jj log -G -T '
    self.change_id().shortest(3)
    ++ " " ++ self.author().name()
    ++ " " ++ self.author().timestamp().format("%Y-%m-%d %H:%M:%S")
    ++ if(self.local_bookmarks(), " " ++ self.local_bookmarks())
    ++ if(self.description(), " " ++ self.description().first_line())
    ++ " " ++ self.commit_id().shortest(3) ++ "\n"
  ' --no-pager "$@" 2>/dev/null
}
alias jl='_jj_log_oneliner -n 20'
