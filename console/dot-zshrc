function goto_repo_root() {
  if git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    cd "$(git rev-parse --show-toplevel)"
  fi
}

function chdir_parent() {
  echo
  cd ..
  zle accept-line
}
