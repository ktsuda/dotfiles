function jj_ai_desc() {
  DIFF=$(git diff --color=never)
  MSG=$(echo "$DIFF" | \
      CLAUDECODE= MAX_THINKING_TOKENS=0 claude -p \
      "Write a concise, one-line commit message for this diff. Output only the text." \
      --no-session-persistence --model=haiku \
      --tools='' --disable-slash-commands \
      --setting-sources='' --system-prompt=''
  )
  jj desc -m "$MSG"
}

