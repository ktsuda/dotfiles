function git_repo_cd() {
  exec </dev/tty
  exec <&1
  local selected_dir
  selected_dir=$(ghq list --full-path | fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort')
  if [ -z "$selected_dir" ]; then
    zle redisplay > /dev/null 2>&1 || true
    return
  fi
  eval 'builtin cd -- "${selected_dir}"'
  zle reset-prompt > /dev/null 2>&1 || true
}
zle -N git_repo_cd
bindkey "^s" git_repo_cd

function subdir_cd() {
  exec </dev/tty
  exec <&1
  local selected_dir
  if (( $+commands[fd] )); then
    selected_dir=$(fd -t d | fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort')
  else
    selected_dir=$(find . -type d | fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort')
  fi
  if [ -z "$selected_dir" ]; then
    zle redisplay > /dev/null 2>&1 || true
    return
  fi
  eval 'builtin cd -- "${selected_dir}"'
  zle reset-prompt > /dev/null 2>&1 || true
}
zle -N subdir_cd
bindkey "^o" subdir_cd

function history_widget() {
  exec </dev/tty
  exec <&1
  local selected num
  selected=($(fc -rl 1 | fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort'))
  if [ -z "$selected" ]; then
    zle redisplay > /dev/null 2>&1 || true
    return
  fi
  num=$selected[1]
  [[ -z "$num" ]] && return
  zle reset-prompt > /dev/null 2>&1 || true
  zle vi-fetch-history -n $num
}
zle -N history_widget
bindkey "^r" history_widget

alias ipv4='ipv4_address'
function ipv4_address() {
  exec </dev/tty
  exec <&1
  local ipv4_address
  ipv4_address=$(ifconfig | \
      awk '$0 ~ /inet [0-9]+.[0-9]+.[0-9]+.[0-9]+/{ print $2 }' | \
      fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort' \
    )
  if [ -z "$ipv4_address" ]; then
    zle redisplay > /dev/null 2>&1 || true
    return
  fi
  zle reset-prompt > /dev/null 2>&1 || true
  echo "$ipv4_address"
}

alias sp='pkg_search'
function pkg_search() {
  exec </dev/tty
  exec <&1
  local selected
  case ${OSTYPE} in
    linux*)
      selected=$(dpkg -l | awk '/^ii/ { print $2 }' | fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort')
      if [ -z "$selected" ]; then
        zle redisplay > /dev/null 2>&1 || true
        return
      fi
      zle reset-prompt > /dev/null 2>&1 || true
      apt-cache depends $selected
      echo
      apt-cache rdepends $selected
      ;;
    darwin*)
      selected=$(brew list -1 | fzf --tmux center,90%,90% --border --bind 'ctrl-c:abort')
      if [ -z "$selected" ]; then
        zle redisplay > /dev/null 2>&1 || true
        return
      fi
      zle reset-prompt > /dev/null 2>&1 || true
      echo "${selected} depends on..."
      brew deps $selected 2>/dev/null
      echo
      echo "${selected} is used by..."
      brew uses --eval-all $selected 2>/dev/null
      echo
      ;;
  esac
}

function custom_tmux_session() {
  exec </dev/tty
  exec <&1
  local session
  if [[ $# -ge 1 ]]; then
    session="$1"
    if [[ -n $TMUX ]]; then
      tmux new-session -d -s"$session"
      tmux switch-client -t "$session"
    else
      tmux new-session -s"$session"
    fi
  else
    session=$(\
        tmux list-sessions 2>/dev/null | \
        fzf --tmux center,90%,90% --border --delimiter : --nth 1 \
        --bind 'ctrl-d:execute(tmux kill-session -t {1})+reload(tmux list-sessions 2>/dev/null)' | \
        cut -d: -f1 \
      )
    zle reset-prompt > /dev/null 2>&1 || true
    if [[ -z "$session" ]]; then
      tmux new-session -s"default"
      return
    fi
    if [[ -n $TMUX ]]; then
      tmux switch-client -t "$session"
    else
      tmux attach-session -t "$session"
    fi
  fi
}

function custom_tmux_send_to() {
  exec </dev/tty
  exec <&1
  if [[ $# -lt 1 ]]; then
    echo "Usage: sa <command>"
    zle redisplay > /dev/null 2>&1 || true
    return
  fi
  local session
  session=$(\
      tmux list-sessions 2>/dev/null | \
      fzf --tmux center,90%,90% --border --delimiter : --nth 1 \
      --bind 'ctrl-d:execute(tmux kill-session -t {1})+reload(tmux list-sessions 2>/dev/null)' | \
      cut -d: -f1 \
    )
  zle reset-prompt > /dev/null 2>&1 || true
  [[ -z "$session" ]] && return
  tmux new-window -t "$session" "$*"
}

function sesh_sessions() {
  exec </dev/tty
  exec <&1
  local session
  session=$(\
      sesh list --icons | \
      fzf --tmux center,90%,90% --border \
      --bind 'ctrl-d:execute(tmux kill-session -t {2..})+reload(sesh list --icons)' \
      --preview-window 'right:55%:noborder' --preview 'sesh preview {}' \
    )
  zle reset-prompt > /dev/null 2>&1 || true
  [[ -z "$session" ]] && return
  sesh connect $session
}

function custom_sesh_send_to() {
  exec </dev/tty
  exec <&1
  if [[ $# -lt 1 ]]; then
    echo "Usage: sa <command>"
    return
  fi
  local session
  session=$(\
      sesh list -t --icons | \
      fzf --tmux center,90%,90% --border --preview-window 'right:55%:noborder' --preview 'sesh preview {}' \
    )
  zle reset-prompt > /dev/null 2>&1 || true
  [[ -z "$session" ]] && return
  tmux new-window -t "$ID" "$*"
}

